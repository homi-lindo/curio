LUME_SYNC_TOKEN=
LUME_SYNC_PORT=8787
LUME_SYNC_MAX_BODY_BYTES=10485760

# Optional CORS for browser-based diagnostics only. Native apps do not need it.
# LUME_SYNC_CORS_ORIGIN=https://example.com

# Tokenless mode is only for loopback development and should stay disabled.
# LUME_SYNC_ALLOW_EMPTY_TOKEN=false

# Optional HTTPS:
# LUME_SYNC_TLS_KEY_PASSWORD=
